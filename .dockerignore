# Data files — mounted at runtime via GCS FUSE or bind-mount
data/
*.duckdb
*.db
*.wal

# Secrets
.env
.env.*
!.env.example

# Virtual environment — rebuilt inside Docker
.venv/

# Git internals and sibling worktrees
.git/
*-worktree/

# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Tests — not needed at runtime
tests/

# Node (Vite build artifacts if generated locally)
node_modules/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
