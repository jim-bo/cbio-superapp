# ── cBioPortal Cloud Run Environment Variables ────────────────────────────────
# Copy to .env and fill in values for local development.
# In production these are injected by Cloud Run — .env is never deployed.

# ── GCP / Artifact Registry ───────────────────────────────────────────────────

# Your GCP project ID (used by tasks.py and gcloud commands)
GCP_PROJECT=your-gcp-project-id

# GCP region for Cloud Run service and Artifact Registry
GCP_REGION=us-central1

# GCS bucket that holds cbioportal.duckdb (managed via: inv sync-db)
CBIO_GCS_BUCKET=your-gcs-bucket

# ── Application ───────────────────────────────────────────────────────────────

# Full GCS URI to the DuckDB file.
# Set this in Cloud Run. Leave unset locally — use CBIO_DB_PATH with a local file.
# When set, the app downloads the file to CBIO_DB_PATH at startup.
# CBIO_GCS_DB_URI=gs://your-gcs-bucket/cbioportal.duckdb

# Filesystem path where DuckDB lives (or will be downloaded to).
#   Local default:  data/cbioportal.duckdb
#   Inside Docker:  /app/data/cbioportal.duckdb
CBIO_DB_PATH=data/cbioportal.duckdb

# SQLAlchemy URL for the sessions database.
#   Local dev:   sqlite:///data/sessions.db  (default, no setup needed)
#   Cloud Run:   postgresql+psycopg2://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
CBIO_SESSIONS_DB_URL=sqlite:///data/sessions.db

# Set to 1 in production (requires HTTPS). 0 for local / HTTP dev.
CBIO_SECURE_COOKIES=0

# Port to listen on. Cloud Run sets this automatically — only override locally.
PORT=8080

# ── Local dev paths (not used in production) ──────────────────────────────────
CBIO_DATAHUB=/path/to/datahub
CBIO_DOWNLOADS=/path/to/downloads
